<html>
<head>
    <title>Tính tích</title>
    <meta charset="UTF-8">
</head>

<body style="font-family:arial">

<h1>Bạn hãy nhập vào số lượng và giá:</h1>

Số lượng: <input id="SoLuong"><br><br>

Đơn giá: 
<input id="DonGia" onkeyup="TinhTien()"><br><br>

Thành tiền: 
<input id="ThanhTien" readonly> USD

<script>
function TinhTien() {
    var soLuong = document.getElementById("SoLuong").value;
    var donGia = document.getElementById("DonGia").value;

    soLuong = parseFloat(soLuong);
    donGia = parseFloat(donGia);

    if (!isNaN(soLuong) && !isNaN(donGia)) {
        document.getElementById("ThanhTien").value = soLuong * donGia;
    } else {
        document.getElementById("ThanhTien").value = "";
    }
}
</script>

</body>
</html>
