<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Sắp xếp mảng</title>
</head>
<body>

<script>
let soLuong;
let DS = []; // khai báo mảng rỗng

soLuong = prompt("Bạn cần nhập bao nhiêu người:", 5);

// nhập danh sách
for (let i = 0; i < soLuong; i++) {
    DS[i] = prompt("Nhập vào họ tên:", "");
}

// sắp xếp theo alphabet
DS.sort();

// hiển thị kết quả
document.write("<h2>Danh sách đã sắp xếp:</h2>");

for (let x in DS) {
    document.write(DS[x] + "<br>");
}
</script>

</body>
</html>
