<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Máy tính đơn giản</title>
    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            text-align: center;
            margin-top: 50px;
        }
        .box {
            background: white;
            padding: 20px;
            width: 300px;
            margin: auto;
            border-radius: 10px;
            box-shadow: 0 0 10px #ccc;
        }
        input {
            margin: 5px;
            padding: 8px;
            width: 80%;
        }
        button {
            margin: 5px;
            padding: 8px 12px;
            cursor: pointer;
        }
    </style>
</head>

<body>

<div class="box">
    <h2>Máy tính đơn giản</h2>

    <input type="text" id="SoHang1" placeholder="Nhập số thứ 1"><br>
    <input type="text" id="SoHang2" placeholder="Nhập số thứ 2"><br>
    <input type="text" id="KetQua" placeholder="Kết quả" readonly><br>

    <button onclick="tinh('+')">Cộng</button>
    <button onclick="tinh('-')">Trừ</button>
    <button onclick="tinh('*')">Nhân</button>
    <button onclick="tinh('/')">Chia</button>
</div>

<script>
function tinh(phepToan) {
    let a = parseFloat(document.getElementById("SoHang1").value) || 0;
    let b = parseFloat(document.getElementById("SoHang2").value) || 0;
    let kq = 0;

    if (phepToan === '+') kq = a + b;
    if (phepToan === '-') kq = a - b;
    if (phepToan === '*') kq = a * b;
    if (phepToan === '/') kq = b !== 0 ? a / b : "Không chia được";

    document.getElementById("KetQua").value = kq;
}
</script>

</body>
</html>
